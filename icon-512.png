<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 400" width="400" height="400">
  <defs>
    <!-- Soft gradient background -->
    <radialGradient id="bgGrad" cx="50%" cy="45%" r="60%">
      <stop offset="0%" stop-color="#e8f4ff"/>
      <stop offset="100%" stop-color="#c8e6ff"/>
    </radialGradient>

    <!-- Icon gradient - warm mint to soft blue -->
    <linearGradient id="iconGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#6dd5b8"/>
      <stop offset="100%" stop-color="#4baee8"/>
    </linearGradient>

    <!-- Path glow -->
    <linearGradient id="pathGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#a8eddb"/>
      <stop offset="100%" stop-color="#7ec8f5"/>
    </linearGradient>

    <!-- Dot accent -->
    <linearGradient id="dotGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#f9a8d4"/>
      <stop offset="100%" stop-color="#f472b6"/>
    </linearGradient>

    <!-- Star accent -->
    <linearGradient id="starGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" stop-color="#fde68a"/>
      <stop offset="100%" stop-color="#fbbf24"/>
    </linearGradient>

    <!-- Drop shadow filter -->
    <filter id="softShadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="0" dy="8" stdDeviation="16" flood-color="#4baee8" flood-opacity="0.18"/>
    </filter>

    <!-- Glow filter for icon -->
    <filter id="iconGlow" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="6" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>

    <!-- Clip for rounded square -->
    <clipPath id="iconClip">
      <rect x="130" y="80" width="140" height="140" rx="38" ry="38"/>
    </clipPath>
  </defs>

  <!-- Background circle -->
  <circle cx="200" cy="200" r="185" fill="url(#bgGrad)" opacity="0.5"/>

  <!-- ── ICON BADGE ── -->
  <!-- Outer soft shadow layer -->
  <rect x="130" y="80" width="140" height="140" rx="38" ry="38"
        fill="white" filter="url(#softShadow)" opacity="0.9"/>

  <!-- Badge fill -->
  <rect x="130" y="80" width="140" height="140" rx="38" ry="38"
        fill="url(#iconGrad)"/>

  <!-- Inner shine -->
  <rect x="130" y="80" width="140" height="70" rx="38" ry="38"
        fill="white" opacity="0.15" clip-path="url(#iconClip)"/>

  <!-- ── LEARNING PATH ICON ── -->
  <!-- Winding path dots representing a learning journey -->
  <!-- Start dot -->
  <circle cx="163" cy="185" r="9" fill="white" opacity="0.95"/>

  <!-- Path curve -->
  <path d="M163 185 Q175 162 193 168 Q211 174 205 155 Q199 136 220 132"
        fill="none" stroke="white" stroke-width="4.5"
        stroke-linecap="round" stroke-dasharray="6 4" opacity="0.7"/>

  <!-- Mid dot -->
  <circle cx="205" cy="155" r="7" fill="white" opacity="0.85"/>

  <!-- End star/flag -->
  <circle cx="220" cy="132" r="10" fill="white" opacity="0.98"/>
  <!-- Star inside end circle -->
  <text x="220" y="137" text-anchor="middle" font-size="12" fill="#4baee8">★</text>

  <!-- Small floating accent dots around badge -->
  <circle cx="248" cy="92" r="5" fill="url(#dotGrad)" opacity="0.85"/>
  <circle cx="122" cy="174" r="4" fill="url(#starGrad)" opacity="0.80"/>
  <circle cx="256" cy="198" r="3.5" fill="url(#pathGrad)" opacity="0.75"/>

  <!-- ── WORDMARK ── -->
  <!-- EduOS -->
  <text x="200" y="278"
        font-family="'Nunito', 'Varela Round', 'Quicksand', 'DM Sans', sans-serif"
        font-size="42" font-weight="800" letter-spacing="-1"
        text-anchor="middle" fill="#1e3a5f">Edu<tspan fill="url(#iconGrad)">OS</tspan></text>

  <!-- Tagline -->
  <text x="200" y="308"
        font-family="'Nunito', 'DM Sans', sans-serif"
        font-size="14.5" font-weight="600" letter-spacing="2.5"
        text-anchor="middle" fill="#6b9cc5" opacity="0.85">THE LEARNING PATH</text>

  <!-- Decorative underline pill -->
  <rect x="170" y="318" width="60" height="3.5" rx="2"
        fill="url(#iconGrad)" opacity="0.5"/>

  <!-- Extra floating sparkles -->
  <text x="148" y="268" font-size="13" opacity="0.4" fill="#fbbf24">✦</text>
  <text x="243" y="262" font-size="9" opacity="0.35" fill="#f472b6">✦</text>
  <text x="155" y="310" font-size="7" opacity="0.3" fill="#4baee8">✦</text>
</svg>
